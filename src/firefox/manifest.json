{
  "manifest_version": 2,
  "name": "WebBrain",
  "version": "0.7.0",
  "description": "Open-source AI browser agent — chat with pages, automate tasks, multi-provider LLM support.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "page": "src/background.html",
    "persistent": false
  },
  "sidebar_action": {
    "default_title": "WebBrain",
    "default_panel": "src/ui/sidepanel.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/ui/settings.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_title": "WebBrain",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "webbrain@esokullu.com",
      "strict_min_version": "109.0"
    }
  }
}
